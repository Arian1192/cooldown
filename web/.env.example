# Client-exposed (bundled into the browser). MUST be prefixed with NEXT_PUBLIC_
NEXT_PUBLIC_SITE_NAME="Music + Urban"

# Server-only (available on the server/runtime only). Do NOT prefix with NEXT_PUBLIC_
# Used for absolute canonical URLs, sitemap, RSS.
# Optional: if not set, Vercel deployments will auto-detect via VERCEL_URL.
# SITE_URL="https://cooldownblog.vercel.app"

# Strapi/CMS API base URL used by server-side data fetching.
# Preferred key:
# STRAPI_URL="https://cms.example.com"
# Legacy alias still supported:
# CMS_BASE_URL="https://cms.example.com"

# Analytics (Umami)
# NEXT_PUBLIC_UMAMI_SCRIPT_URL="https://umami.example.com/script.js"
# NEXT_PUBLIC_UMAMI_WEBSITE_ID="00000000-0000-0000-0000-000000000000"

# Content repository source:
# - versioned-json: reads from src/data/content.v1.json
# - remote-json: reads from CONTENT_JSON_URL
# - strapi: reads from STRAPI_URL/api/weekly-discover-feed and merges non-weekly content from versioned JSON
# Defaults: STRAPI_URL=https://cms-cooldown-roan.ariancoro.com, CONTENT_SOURCE=strapi
# CONTENT_SOURCE="strapi"
# CONTENT_JSON_URL="https://example.com/content-feed.json"
# CONTENT_ENABLE_SEED_FALLBACK="true"
