# Client-exposed (bundled into the browser). MUST be prefixed with NEXT_PUBLIC_
NEXT_PUBLIC_SITE_NAME="Music + Urban"

# Server-only (available on the server/runtime only). Do NOT prefix with NEXT_PUBLIC_
# Used for absolute canonical URLs, sitemap, RSS.
# Optional: if not set, Vercel deployments will auto-detect via VERCEL_URL.
# SITE_URL="https://cooldownblog.vercel.app"

# CMS_BASE_URL="https://example.com"
